# Server
PORT=3000
NODE_ENV=development
API_BASE_URL=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/raisa_diary

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars
JWT_REFRESH_SECRET=change-this-refresh-secret-too
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI (Tahsin AI)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Email (verification & password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Tahsin <noreply@raisadiary.com>"

# Cloudinary (media uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# App
APP_NAME="Jannatul Maowa Raisa's Diary"
FRONTEND_URL=http://localhost:8080

# Netlify / Web (comma-separated origins for CORS)
# CORS_ORIGINS=http://localhost:8080,https://your-app.netlify.app
